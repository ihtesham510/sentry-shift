{
	"name": "sentry-shift",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.4.2",
			"zod": "^4.4.3",
			"@types/bun": "^1.3.14",
			"hono": "^4.12.27",
			"@trpc/server": "^11.18.0",
			"better-auth": "1.6.23",
			"lucide-react": "^1.23.0",
			"next-themes": "^0.4.6",
			"sonner": "^2.0.7",
			"@trpc/tanstack-react-query": "^11.18.0",
			"@trpc/client": "^11.18.0",
			"@tanstack/react-query": "^5.101.2",
			"@tanstack/react-form": "^1.33.0",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.3.2",
			"tailwind-merge": "^3.6.0",
			"@better-auth/expo": "1.6.23"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"dev:native": "turbo run dev -F native",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:push": "turbo run db:push -F @sentry-shift/db",
		"db:studio": "turbo run db:studio -F @sentry-shift/db",
		"db:generate": "turbo run db:generate -F @sentry-shift/db",
		"db:migrate": "turbo run db:migrate -F @sentry-shift/db",
		"db:start": "turbo run db:start -F @sentry-shift/db",
		"db:watch": "turbo run db:watch -F @sentry-shift/db",
		"db:stop": "turbo run db:stop -F @sentry-shift/db",
		"db:down": "turbo run db:down -F @sentry-shift/db",
		"deploy:setup": "vercel link",
		"dev:vercel": "vercel dev -L",
		"env:preview": "tsx scripts/sync-vercel-env.ts preview",
		"env:production": "tsx scripts/sync-vercel-env.ts production",
		"deploy": "vercel deploy",
		"deploy:prod": "vercel deploy --prod",
		"deploy:check": "vercel deploy --dry",
		"check": "biome check --write --unsafe .",
		"prepare": "husky"
	},
	"dependencies": {
		"@sentry-shift/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@sentry-shift/config": "workspace:*",
		"@types/bun": "catalog:",
		"@types/node": "^22.13.14",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsx": "^4.22.5",
		"turbo": "^2.10.2",
		"typescript": "^6",
		"vercel": "^54.18.6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.14"
}
